# Django
DJANGO_SECRET_KEY=change-me-in-production-use-django-admin-generate-secret
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Firebase Authentication (all optional — leave empty to disable auth UI)
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_APP_ID=
REQUIRE_LOGIN=False

# Market Data API Keys (at least one recommended; yfinance works without keys)
FINNHUB_API_KEY=
ALPHA_VANTAGE_API_KEY=
TWELVE_DATA_API_KEY=
POLYGON_API_KEY=

# News APIs
NEWSAPI_KEY=
MARKETAUX_API_KEY=

# Cache (optional - falls back to local memory)
REDIS_URL=

# Rate limit settings (requests per minute)
FINNHUB_RATE_LIMIT=60
ALPHA_VANTAGE_RATE_LIMIT=5
